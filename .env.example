# -------------------------------
# OAuth Configuration
# -------------------------------
GOOGLE_CLIENT_ID=ENTER_YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=ENTER_YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=ENTER_YOUR_GOOGLE_REDIRECT_URI
GOOGLE_API_KEY=ENTER_YOUR_GOOGLE_API_KEY

FB_APP_ID=ENTER_YOUR_FACEBOOK_APP_ID
FB_APP_SECRET=ENTER_YOUR_FACEBOOK_APP_SECRET

TWITTER_KEY=ENTER_YOUR_TWITTER_KEY
TWITTER_SECRET=ENTER_YOUR_TWITTER_SECRET

# -------------------------------
# Database
# -------------------------------
MONGO_URI=ENTER_YOUR_MONGODB_URI

# -------------------------------
# Email Configuration
# -------------------------------
EMAIL_USER=ENTER_YOUR_EMAIL
EMAIL_PASS=ENTER_YOUR_EMAIL_APP_PASSWORD

# -------------------------------
# Server Configuration
# -------------------------------
PORT=5000
BASE_URL=http://localhost:5000
ENABLE_NGROK=true
NGROK_AUTHTOKEN=ENTER_YOUR_NGROK_AUTH_TOKEN
FILES_META=./filesMeta.json

# -------------------------------
# Admin Credentials
# -------------------------------
SUPER_ADMIN_EMAIL=Create your Super Admin Mail (like Owner@cloudspace.com)
SUPER_ADMIN_PASSWORD=ENTER_SUPER_ADMIN_PASSWORD

ADMIN_EMAIL=admin@cloudspace.com
ADMIN_PASSWORD=ENTER_ADMIN_PASSWORD

# Admin Privacy PIN
ADMIN_PRIVACY_PIN=ENTER_ADMIN_PIN

# -------------------------------
# Coupon Configuration
# -------------------------------
COUPON_CODE=GET50
DISCOUNT_PERCENT=50
UPI_ID=ENTER_YOUR_UPI_ID
UPI_NAME=ENTER_YOUR_NAME
PRICE_PER_TB=450

# -------------------------------
# Cloud Coins Discount
# -------------------------------
COINS_DISCOUNT_ENABLED=true
COINS_PER_RUPEE=5
# 500 coins = 100 rs discount (5 coins = 1 rupee)

# -------------------------------
# Security
# -------------------------------
JWT_SECRET=ENTER_STRONG_RANDOM_SECRET

# -------------------------------
# Storage / Sync
# -------------------------------
SYNC_FOLDER=./uploads

# -------------------------------
# TeraBox Configuration
# -------------------------------
TERABOX_EMAIL=ENTER_TERABOX_EMAIL
TERABOX_PASSWORD=ENTER_TERABOX_PASSWORD

# -------------------------------
# Auto Plan Generation
# -------------------------------
AUTO_GENERATE_PLANS=true

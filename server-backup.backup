// ================== ADMIN: SEND MAIL ==================
app.post("/admin/send-mail", verifyToken, isAdmin, async (req, res) => {
    const { to, subject, message } = req.body;

    if (!subject || !message) {
        return res.status(400).json({ error: "Subject and message required" });
    }

    // Load all users
    let users = JSON.parse(fs.readFileSync(usersFile));
    let recipients = [];

    // ✅ Build recipients
    if (!to || to === "all") {
        recipients = users.map(u => u.email);
    } else if (to === "admins") {
        recipients = users.filter(u => u.role === "admin").map(u => u.email);
    } else if (to === "users") {
        recipients = users.filter(u => u.role !== "admin").map(u => u.email);
    } else if (to === "active") {
        recipients = users.filter(u => !u.blocked).map(u => u.email);
    } else if (to === "blocked") {
        recipients = users.filter(u => u.blocked).map(u => u.email);
    } else if (Array.isArray(to)) {
        // 🎯 Multiple selected users
        recipients = users.filter(u => to.includes(u.email)).map(u => u.email);
    } else {
        // 🎯 Single specific user
        const user = users.find(u => u.email === to.trim());
        if (!user) return res.status(404).json({ error: "User not found" });
        recipients = [user.email];
    }

    if (!recipients.length) {
        return res.status(400).json({ error: "No recipients found" });
    }

    try {
        // ✨ Use styled mail system
        await sendStyledMail(
            recipients.join(","),
            subject,
            `
            <h2 style="color:#00ffcc;text-align:center;">📢 Cloud Space Notification</h2>
            <p style="font-size:15px;line-height:1.6;color:#ddd;">
                ${message.replace(/\n/g, "<br>")}
            </p>
            <hr style="border:none;border-top:1px solid #333;margin:20px 0;" />
            <p style="text-align:center;color:#888;font-size:12px;">
                🚀 Sent securely from <b>Cloud Space Admin Panel</b>
            </p>
            `
        );

        // ✅ Log mail activity
        fs.appendFileSync(
            mailLog,
            `${new Date().toISOString()} | Sent to: ${recipients.join(", ")} | Subject: ${subject}\n`
        );

        res.json({ message: `✅ Mail sent to ${recipients.length} user(s)` });
    } catch (err) {
        console.error("❌ Mail error:", err);
        res.status(500).json({ error: "❌ Failed to send email" });
    }
});

// ⏳ Auto-Block Inactive (not verified in 10 minutes)
app.post("/admin/auto-block", verifyToken, isAdmin, (req, res) => {
    let users = JSON.parse(fs.readFileSync(usersFile));
    const now = Date.now();
    let blockedCount = 0;

    users.forEach(u => {
        // If user not verified and created_at older than 10 minutes
        if (!u.verified && new Date(u.created_at).getTime() < now - 10 * 60 * 1000) {
            u.blocked = true;
            blockedCount++;
        }
    });

    fs.writeFileSync(usersFile, JSON.stringify(users, null, 2));
    res.json({ message: `🚫 ${blockedCount} users auto-blocked (older than 10 min).` });
});


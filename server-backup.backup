// 📊 Get all JSON data for dashboard
app.get("/api/admin/all-json-data", verifyToken, isAdmin, (req, res) => {
    try {
        // Read all JSON files
        const proofs = JSON.parse(fs.readFileSync(path.join(__dirname, 'support', 'payments', 'proofs.json'), 'utf8'));
        const purchases = JSON.parse(fs.readFileSync(purchasesFile, 'utf8'));
        const planActive = JSON.parse(fs.readFileSync(planActiveFile, 'utf8'));
        const planPrice = JSON.parse(fs.readFileSync(planPriceFile, 'utf8'));
        const users = JSON.parse(fs.readFileSync(usersFile, 'utf8'));
        
        // Remove sensitive data from users
        const safeUsers = users.map(({ password, ...rest }) => rest);
        
        res.json({
            proofs,
            purchases,
            planActive,
            planPrice,
            users: safeUsers,
            timestamp: new Date().toISOString()
        });
    } catch (error) {
        console.error('Error reading JSON files:', error);
        res.status(500).json({ error: 'Failed to fetch JSON data', details: error.message });
    }
});

    // 📝 Update User data
    app.put("/api/admin/update-user", verifyToken, isAdmin, (req, res) => {
        try {
            const { email, updatedData } = req.body;
            if (!email || !updatedData) {
                return res.status(400).json({ error: 'Email and updated data are required' });
            }

            let users = JSON.parse(fs.readFileSync(usersFile, 'utf8'));
            const userIndex = users.findIndex(u => u.email === email);
        
            if (userIndex === -1) {
                return res.status(404).json({ error: 'User not found' });
            }

            // Preserve password if not provided in update
            if (!updatedData.password) {
                updatedData.password = users[userIndex].password;
            }

            users[userIndex] = { ...users[userIndex], ...updatedData };
            fs.writeFileSync(usersFile, JSON.stringify(users, null, 2));

            fs.appendFileSync(
                flagsLog,
                `${new Date().toISOString()} | 📝 User ${email} updated by ${req.user.email}\n`
            );

            res.json({ success: true, message: 'User updated successfully', user: users[userIndex] });
        } catch (error) {
            console.error('Error updating user:', error);
            res.status(500).json({ error: 'Failed to update user', details: error.message });
        }
    });

    // 📝 Update Purchase data
    app.put("/api/admin/update-purchase", verifyToken, isAdmin, (req, res) => {
        try {
            const { transactionId, updatedData } = req.body;
            if (!transactionId || !updatedData) {
                return res.status(400).json({ error: 'Transaction ID and updated data are required' });
            }

            let purchases = JSON.parse(fs.readFileSync(purchasesFile, 'utf8'));
            const purchaseIndex = purchases.findIndex(p => p.transactionId === transactionId);
        
            if (purchaseIndex === -1) {

// Socket.IO removed; no realtime placeholder
// ================== UPDATE PROFILE ==================
app.post("/update-profile", uploadProfile.single("profilePic"), (req, res) => {
    let email = normalizeEmail(req.body.email);
    const uid = req.body.uid;
    // If email not provided, try to lookup by uid
    if (!email && uid) {
        try {
            const all = JSON.parse(fs.readFileSync(usersFile, 'utf8'));
            const found = all.find(u => u.uid === uid);
            if (found && found.email) email = normalizeEmail(found.email);
        } catch (e) {
            console.error('UID lookup failed in update-profile', e);
        }
    }
    const username = req.body.username;
    const phone = req.body.phone;
    if (!email) return res.status(400).json({ error: "Email required" });

    let users = JSON.parse(fs.readFileSync(usersFile));
    const idx = users.findIndex(u => normalizeEmail(u.email) === email || (req.body.uid && u.uid === req.body.uid));
    if (idx === -1) return res.status(404).json({ error: "User not found" });

    // Update fields
    if (username) users[idx].username = username;
    if (phone) users[idx].phone = phone;

    // ✅ Save new profile picture if uploaded
    if (req.file) {
        users[idx].profilePic = `/uploads/${safeName(email)}/profile/${req.file.filename}`;
    }

    fs.writeFileSync(usersFile, JSON.stringify(users, null, 2));
    const { password, ...safeUser } = users[idx];
    res.json({ message: "✅ Profile updated", user: safeUser });
});


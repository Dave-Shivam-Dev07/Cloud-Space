// PREMIUM PLANS + PAYMENT SYSTEM (QR BASED)
// =========================
// ✅ UPI CONFIG (Replace this with your actual ID)
const UPI_ID = process.env.UPI_ID || "9316378005-2.wallet@phonepe";

// ✅ Load plan details from plan-price.json (single source of truth)
const planPriceFile = path.join(supportDir, "plan-price.json");
let PLANS = {};
const DEFAULT_PLAN_PAYLOAD = {
    plans: {
        silver: { key: "silver", name: "Silver", amount: 5 * PRICE_PER_TB, storageTB: 5, durationDays: 30, note: "Monthly (30 days)" },
        gold: { key: "gold", name: "Gold", amount: 20 * PRICE_PER_TB, storageTB: 20, durationDays: 90, note: "Quarterly (90 days)" },
        platinum: { key: "platinum", name: "Platinum", amount: 100 * PRICE_PER_TB, storageTB: 100, durationDays: 180, note: "Half-yearly (180 days)" },
        ultra: { key: "ultra", name: "Ultra", amount: 200 * PRICE_PER_TB, storageTB: 200, durationDays: 9999, note: "Lifetime" }
    },
    upiId: process.env.UPI_ID || "mycloudspace@upi",
    lastUpdated: new Date().toISOString(),
    pricePerTB: PRICE_PER_TB
};

function rebuildPlansWithRate(sourcePlans, rate) {
    const plans = {};
    Object.entries(sourcePlans || {}).forEach(([key, plan]) => {
        const storageTB = Number(plan.storageTB) || 0;
        const amount = Math.max(0, Math.round(storageTB * rate));
        plans[key] = { ...plan, key: plan.key || key, amount };
    });
    return plans;
}

// Utility: read plan-active.json safely
function readPlanActiveFile() {
    try {
        return JSON.parse(fs.readFileSync(planActiveFile, "utf8") || "[]");
    } catch (err) {
        console.error("⚠️ Failed to read plan-active.json", err);
        return [];
    }
}

// Utility: write plan-active.json
function writePlanActiveFile(data) {
    try {
        fs.writeFileSync(planActiveFile, JSON.stringify(data, null, 2));
    } catch (err) {
        console.error("⚠️ Failed to write plan-active.json", err);
    }
}

// Ensure plan-price.json exists on startup with defaults
function ensurePlanPriceFile() {
    try {
        if (fs.existsSync(planPriceFile)) return;
        const rate = PRICE_PER_TB;
        const upi = process.env.UPI_ID || "mycloudspace@upi";
        const plans = rebuildPlansWithRate(DEFAULT_PLAN_PAYLOAD.plans, rate);
        const payload = {
            plans,
            upiId: upi,
            pricePerTB: rate,
            lastUpdated: new Date().toISOString()
        };
        fs.writeFileSync(planPriceFile, JSON.stringify(payload, null, 2));
        console.log("✅ plan-price.json auto-created with defaults");
    } catch (err) {
        console.error("⚠️ Failed to create plan-price.json", err);
    }
}

function loadPlans() {
    try {
        const rate = PRICE_PER_TB; // env-driven single source
        let fileData = null;
        let shouldRewrite = false;

        if (fs.existsSync(planPriceFile)) {
            fileData = JSON.parse(fs.readFileSync(planPriceFile, "utf8"));
            console.log("✅ Plans loaded from plan-price.json");
        } else {
            console.warn("⚠️ plan-price.json not found, creating with defaults");
            fileData = { ...DEFAULT_PLAN_PAYLOAD };
            shouldRewrite = true;
        }

        const rebuiltPlans = rebuildPlansWithRate(fileData.plans || DEFAULT_PLAN_PAYLOAD.plans, rate);
        PLANS = rebuiltPlans;

        // Always sync pricePerTB, upiId, and recalculate plan amounts from .env
        const envPricePerTB = Number(rate);
        const envUpiId = process.env.UPI_ID || "mycloudspace@upi";
        
        // Check if amounts need recalculation based on current PRICE_PER_TB
        let amountsNeedUpdate = false;
        if (fileData.plans) {
            Object.entries(fileData.plans).forEach(([key, plan]) => {
                const expectedAmount = Math.round((plan.storageTB || 0) * envPricePerTB);
                if (plan.amount !== expectedAmount) {
                    amountsNeedUpdate = true;
                }
            });
        }
        
        if (fileData.pricePerTB !== envPricePerTB || fileData.upiId !== envUpiId || amountsNeedUpdate) {
            fileData.pricePerTB = envPricePerTB;
            fileData.upiId = envUpiId;
            // Recalculate all plan amounts based on current PRICE_PER_TB
            Object.entries(fileData.plans || {}).forEach(([key, plan]) => {
                fileData.plans[key].amount = Math.round((plan.storageTB || 0) * envPricePerTB);
            });
            fileData.lastUpdated = new Date().toISOString();
            fs.writeFileSync(planPriceFile, JSON.stringify(fileData, null, 2));
            console.log(`✅ Updated plan amounts based on PRICE_PER_TB=${envPricePerTB} from .env`);
        }
    } catch (err) {
        console.error("❌ Error loading plans:", err);
        PLANS = DEFAULT_PLAN_PAYLOAD.plans;
    }
}

// Load plans on startup (auto-create file first)
ensurePlanPriceFile();
loadPlans();

// Auto-reload plans if plan-price.json changes on disk
let planReloadTimer = null;
fs.watchFile(planPriceFile, { interval: 1000 }, () => {
    if (planReloadTimer) return;
    planReloadTimer = setTimeout(() => {
        planReloadTimer = null;
        console.log("♻️ Detected plan-price.json change → reloading plans");
        loadPlans();
    }, 500);
});

// Migrate any legacy plan fields stored in users.json into plan-active.json
function migrateUsersPlansToPlanActive() {
    try {
        const users = JSON.parse(fs.readFileSync(usersFile, "utf8") || "[]");
        const existingPlanActive = readPlanActiveFile();
        const map = new Map();

        existingPlanActive.forEach(entry => {
            if (entry?.self?.uid) {
                map.set(entry.self.uid, entry);
            }
        });

        let usersUpdated = false;
        const now = Date.now();

        users.forEach((user) => {
            if (!user.uid) return;
            const plan = user.plan;
            const storageTB = user.storageTB;
            const planExpiry = user.planExpiry;

            if (!plan || plan === "free") return;

            let entry = map.get(user.uid);
            if (!entry) {
                entry = {
                    self: {
                        uid: user.uid,
                        email: user.email,
                        username: user.username,
                    },
                    plans: [],
                    summary: {
                        totalPlans: 0,
                        activePlans: 0,
                        blockedPlans: 0,
                        totalSpent: 0,
                        totalDiscount: 0,
                        totalStorage: 0,
                        totalStorageTB: 0,
                    },
                };
                map.set(user.uid, entry);
            }

            const alreadyMigrated = (entry.plans || []).some(p => {
                const tid = (p.transaction?.transactionId) || p.recordId || "";
                return typeof tid === "string" && tid.startsWith("MIGRATED-");
            });
            if (alreadyMigrated) return;

            const selected = PLANS[plan] || {};
            const durationDays = selected.durationDays || null;
            const expiresAt = planExpiry
                ? new Date(planExpiry).toISOString()
                : (durationDays === 9999 ? null : null);
            const active = !planExpiry || Number(planExpiry) > now;
            const storageValue = storageTB || selected.storageTB || 0.5;
            const migratedRecordId = `MIGRATED-${user.uid}`;

            const planRecord = {
                plan,
                planDetails: {
                    storage: storageValue,
                    storageTB: storageValue,
                    durationDays: durationDays,
                    maxUploadSize: getPlanUploadSize(plan),
                    features: getPlanFeatures(plan, storageValue, durationDays || 0),
                },
                transaction: {
                    transactionId: migratedRecordId,
                    paymentMethod: "migrated",
                    currency: "INR",
                    amount: selected.amount || 0,
                    amountDiscount: 0,
                    discountApplied: 0,
                    finalAmount: selected.amount || 0,
                    purchasedAt: user.created_at || new Date().toISOString(),
                    activatedAt: user.created_at || new Date().toISOString(),
                    expiresAt,
                    status: active ? "completed" : "expired",
                    notes: "Migrated from users.json",
                },
                status: {
                    isActive: active,
                    isBlocked: !!user.blocked,
                    blockedReason: user.blocked ? "user blocked" : null,
                    blockedAt: null,
                },
                recordId: migratedRecordId,
            };

            entry.plans = entry.plans || [];
            entry.plans.push(planRecord);
        });

        // Recompute summaries and write plan-active
        const nextPlanActive = Array.from(map.values()).map((entry) => {
            const summary = {
                totalPlans: 0,
                activePlans: 0,
                blockedPlans: 0,
                totalSpent: 0,
                totalDiscount: 0,
                totalStorage: 0,
                totalStorageTB: 0,
            };

            (entry.plans || []).forEach((p) => {
                summary.totalPlans += 1;
                if (p.status?.isActive && !p.status?.isBlocked) summary.activePlans += 1;
                if (p.status?.isBlocked) summary.blockedPlans += 1;
                summary.totalSpent += p.transaction?.finalAmount || 0;
                summary.totalDiscount += p.transaction?.amountDiscount || 0;
                summary.totalStorage += p.planDetails?.storage || 0;
                summary.totalStorageTB += p.planDetails?.storageTB || 0;
            });

            return { ...entry, summary };
        });

        writePlanActiveFile(nextPlanActive);

        // Strip plan fields from users.json to keep it plan-free
        users.forEach((u) => {
            if (u.plan || u.storageTB || u.planExpiry) {
                delete u.plan;
                delete u.storageTB;
                delete u.planExpiry;
                               delete u.purchasedAt;
                usersUpdated = true;
            }
        });

        if (usersUpdated) {
            fs.writeFileSync(usersFile, JSON.stringify(users, null, 2));
            console.log("🔄 Users migrated: plan fields removed from users.json");
        }

        console.log("✅ Users migrated into plan-active.json (legacy plans)");
    } catch (err) {
        console.error("❌ Failed to migrate users into plan-active.json", err);
    }
}


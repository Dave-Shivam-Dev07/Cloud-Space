// Helper: get active plan snapshot for a user from plan-active.json
function getActivePlanSnapshot(uid) {
    const planActive = readPlanActiveFile();
    const entry = planActive.find((u) => u?.self?.uid === uid);
    if (!entry) return { plan: 'free', storageTB: 0.5, planExpiry: null, purchasedAt: null };

    const candidates = (entry.plans || []).filter((p) => p.status?.isActive && !p.status?.isBlocked).sort((a, b) => {
        const aTs = new Date(a.transaction?.activatedAt || 0).getTime();
        const bTs = new Date(b.transaction?.activatedAt || 0).getTime();
        return bTs - aTs;
    });
    const fallback = (entry.plans || []).slice().sort((a, b) => {
        const aTs = new Date(a.transaction?.activatedAt || 0).getTime();
        const bTs = new Date(b.transaction?.activatedAt || 0).getTime();
        return bTs - aTs;
    });

    const chosen = candidates.length ? candidates[0] : (fallback[0] || null);
    if (!chosen) return { plan: 'free', storageTB: 0.5, planExpiry: null, purchasedAt: null };

    const expiresAt = chosen.transaction?.expiresAt;
    const planExpiry = expiresAt ? new Date(expiresAt).getTime() : null;
    const storageTB = chosen.planDetails?.storageTB ?? 0.5;
    const purchasedAt = chosen.transaction?.purchasedAt ? new Date(chosen.transaction.purchasedAt).getTime() : null;
    return { plan: chosen.plan || 'free', storageTB, planExpiry, purchasedAt };
}

// Get user plan details by uid (used by frontend)
app.get('/user-plan/:uid', (req, res) => {
    try {
        const uid = (req.params.uid || '').trim();
        const snapshot = getActivePlanSnapshot(uid);
        return res.json({ success: true, ...snapshot });
    } catch (err) {
        console.error('Error fetching plan', err);
        return res.status(500).json({ success: false, error: 'Server error' });
    }
});

// Get all plans and pricing from JSON files
app.get('/api/plans-pricing', (req, res) => {
    try {
        // Read plan pricing from JSON
        const planPricePath = path.join(__dirname, 'support', 'plan-price.json');
        let plansData = [];

        if (fs.existsSync(planPricePath)) {
            const content = fs.readFileSync(planPricePath, 'utf-8');
            const jsonData = JSON.parse(content);
            
            // Map JSON data to plan cards format
            if (jsonData.plans && typeof jsonData.plans === 'object') {
                // Handle plan-price.json structure with plans object
                Object.entries(jsonData.plans).forEach(([key, plan]) => {
                    // Convert amount from paise to rupees (amount / 100)
                    const priceInRupees = (plan.amount || 0) / 100;
                    const storageGB = (plan.storageTB || 0) * 1024; // Convert TB to GB
                    
                    plansData.push({
                        name: plan.name || 'Plan',
                        price: priceInRupees,
                        storage: storageGB > 0 ? (plan.storageTB + ' TB') : '0 GB',
                        features: plan.features || [
                            `${plan.storageTB || 0} TB Storage`,
                            `${plan.durationDays || 30} Days Access`,
                            plan.note || ''
                        ],
                        badge: key.toUpperCase(),
                        key: key
                    });
                });
            } else if (Array.isArray(jsonData)) {
                // Handle array format
                plansData = jsonData.map(plan => ({
                    name: plan.name || 'Plan',
                    price: parseFloat(plan.price) || 0,
                    storage: plan.storage || '0 GB',
                    features: plan.features || [],
                    badge: plan.badge || 'PLAN'
                }));
            }
        }

        // Default plans if file doesn't exist or is empty
        if (plansData.length === 0) {
            plansData = [
                {
                    name: 'Basic',
                    price: 4.99,
                    storage: '10 GB',
                    features: ['10 GB Storage', 'Basic Support', '5 File Uploads/Day'],
                    badge: 'STARTER'
                },
                {
                    name: 'Platinum',
                    price: 19.99,
                    storage: '1 TB',
                    features: ['1 TB Storage', '24/7 Support', 'Unlimited Uploads'],
                    badge: 'POPULAR'
                },
                {
                    name: 'Ultra',
                    price: 49.99,
                    storage: 'Unlimited',
                    features: ['Unlimited Storage', 'Priority Support', 'Advanced Analytics'],
                    badge: 'ULTIMATE'
                }
            ];
        }

        return res.json(plansData);
    } catch (error) {
        console.error('Error fetching plans pricing:', error);
        return res.status(500).json({ success: false, error: 'Error loading plans' });
    }
});

// 🔐 Get platinum/ultra access token (for purchased users)
app.get('/get-platinum-token/:uid', (req, res) => {
    try {
        const uid = (req.params.uid || '').trim();
        if (!uid) return res.status(400).json({ success: false, error: 'UID required' });
        
        const token = getTokenByUID(uid);
        if (!token) {
            return res.status(404).json({ success: false, error: 'No active token for this user' });
        }
        
        return res.json({ success: true, token: token.token });
    } catch (err) {
        console.error('Error getting token', err);
        return res.status(500).json({ success: false, error: 'Server error' });
    }
});


/* ===================================================
   UPLOAD ROUTES
=================================================== */

// Normal upload
app.post("/upload", uploadFiles.array("files"), (req, res) => {
    if (!req.files?.length) return res.status(400).json({ error: "No files uploaded" });

    const uploadedBy = safeName(resolveUploadedBy(req));
    console.log("📥 Normal upload from:", req.body.uploadedBy, req.headers["x-user"]);
    const host = req.headers.host || `localhost:${PORT}`;

    let filesMeta = JSON.parse(fs.readFileSync(filesMetaFile));
    const fileUrls = req.files.map(file => {
        const ctx = resolveUserContext(req);
        const dirs = ensureUserDirs(ctx.email, ctx.uid);
        const uploadedBy = ctx.uid || ctx.email || "guest";
        const host = req.headers.host || `localhost:${PORT}`;

        const fileData = {
          filename: file.filename,
          originalname: file.originalname,
          bytes: file.size,
          created_at: new Date(),
          secure_url: `http://${host}/uploads/${dirs.pathSegment}/files/${file.filename}`,
          format: path.extname(file.originalname).substring(1).toLowerCase() || "unknown",
          uploadedBy,
          ownerEmail: ctx.email || null,
          ownerUid: ctx.uid || null,
        };
        filesMeta.push(fileData);
        return fileData;
    });
    fs.writeFileSync(filesMetaFile, JSON.stringify(filesMeta, null, 2));

    res.json({ message: "✅ Files uploaded", files: fileUrls });
});

// ================== Chunk Upload ==================
const chunkStorage = multer.diskStorage({
    destination: (req, file, cb) => {
        const uploadedBy = safeName(resolveUploadedBy(req));

        // ✅ get fileId from query/header/body
        const fileId = req.query.fileId || req.headers["x-file-id"] || req.body.fileId;
        if (!fileId) {
            console.error("❌ fileId missing in request!");
            return cb(new Error("Missing fileId"), null);
        }

        const tempDir = path.join(uploadsDir, uploadedBy, "chunks", fileId);
        if (!fs.existsSync(tempDir)) fs.mkdirSync(tempDir, { recursive: true });

        console.log(`📥 Chunk upload from: ${uploadedBy}, fileId=${fileId}`);
        cb(null, tempDir);
    },
    filename: (req, file, cb) => {
        let chunkIndex = 0;

        if (req.query.chunkIndex !== undefined) {
            chunkIndex = parseInt(req.query.chunkIndex, 10);
        } else if (req.headers["x-chunk-index"] !== undefined) {
            chunkIndex = parseInt(req.headers["x-chunk-index"], 10);
        } else if (req.body.chunkIndex !== undefined) {
            chunkIndex = parseInt(req.body.chunkIndex, 10);
        }

        if (isNaN(chunkIndex)) chunkIndex = 0; // ✅ fallback
        cb(null, `${chunkIndex}.part`);
    }
});

const uploadChunk = multer({ storage: chunkStorage });

app.post("/upload-chunk", uploadChunk.single("chunk"), (req, res) => {
    const chunkIndex = req.query.chunkIndex || req.body.chunkIndex || req.headers["x-chunk-index"];
    res.json({ message: `✅ Chunk ${chunkIndex} stored` });
});


// ================== Merge Chunks ==================
app.post("/merge-chunks", (req, res) => {
    const { fileId, fileName } = req.body;
    const uploadedBy = req.body.uploadedBy || resolveUploadedBy(req);
    if (!fileId || !fileName || !uploadedBy) {
        return res.status(400).json({ error: "❌ Missing fileId, fileName or uploadedBy" });
    }

    const safeEmail = safeName(uploadedBy || req.headers["x-user"] || "guest");
    const chunkDir = path.join(uploadsDir, safeEmail, "chunks", fileId);
    const finalDir = path.join(uploadsDir, safeEmail, "files");
    if (!fs.existsSync(finalDir)) fs.mkdirSync(finalDir, { recursive: true });

    let chunkFiles = fs.readdirSync(chunkDir).filter(f => f.endsWith(".part"));
    if (chunkFiles.length === 0) {
        return res.status(400).json({ error: "❌ No chunks found for file" });
    }

    // ✅ sort numerically, not lexically
    chunkFiles.sort((a, b) => parseInt(a) - parseInt(b));
    console.log("🔗 Merging chunks:", chunkFiles);

    const finalPath = path.join(finalDir, fileName);
    const writeStream = fs.createWriteStream(finalPath);

    let idx = 0;
    function appendNext() {
        if (idx >= chunkFiles.length) {
            writeStream.end();
            fs.rmSync(chunkDir, { recursive: true, force: true });

            let filesMeta = JSON.parse(fs.readFileSync(filesMetaFile));
            const host = req.headers.host || `localhost:${PORT}`;
            const fileData = {
                filename: path.basename(finalPath),
                originalname: fileName,
                bytes: fs.statSync(finalPath).size,
                created_at: new Date(),
                secure_url: `http://${host}/uploads/${safeEmail}/files/${path.basename(finalPath)}`,
                format: path.extname(fileName).substring(1).toLowerCase() || "unknown",
                uploadedBy,
            };
            filesMeta.push(fileData);
            fs.writeFileSync(filesMetaFile, JSON.stringify(filesMeta, null, 2));

            return res.json({ message: "✅ File merged successfully", file: fileData });
        }

        const chunkPath = path.join(chunkDir, chunkFiles[idx]);
        const readStream = fs.createReadStream(chunkPath);

        readStream.pipe(writeStream, { end: false });
        readStream.on("end", () => {
            fs.unlinkSync(chunkPath);
            idx++; // ✅ FIX: increment index
            appendNext();
        });
        readStream.on("error", err => {
            console.error("❌ Merge error at:", chunkPath, err);
            res.status(500).json({ error: "Failed during merge", details: err.message });
        });
    }

    appendNext();
});

// ================== List all files ==================
app.get("/files", (req, res) => {
    try {
        let filesMeta = JSON.parse(fs.readFileSync(filesMetaFile, "utf8"));
        res.json(filesMeta);
    } catch (err) {
        console.error("❌ Error reading files:", err);
        res.status(500).json({ error: "Failed to fetch all files" });
    }
});

// ========== List files per user ==========
app.get("/files/:email", (req, res) => {
    const email = normalizeEmail(req.params.email);
    const safeEmail = safeName(email);

    try {
        let filesMeta = JSON.parse(fs.readFileSync(filesMetaFile, "utf8"));

        // ✅ normalize both sides
        const userFiles = filesMeta.filter(f => safeName(normalizeEmail(f.uploadedBy)) === safeEmail);

        res.json(userFiles);
    } catch (err) {
        console.error("❌ Error reading user files:", err);
        res.status(500).json({ error: "Failed to fetch user files" });
    }
});

// ================== USER STORAGE ==================
// ✅ Updated dynamic storage API
app.get("/storage/:email", (req, res) => {
    const email = normalizeEmail(req.params.email);
    const safeEmail = safeName(email);
    let users = JSON.parse(fs.readFileSync(usersFile, "utf8"));
    const user = users.find((u) => u.email === email);

    const snapshot = user?.uid ? getActivePlanSnapshot(user.uid) : { plan: "free", storageTB: 0.5, planExpiry: null };
    const now = Date.now();
    let maxTB = snapshot.storageTB || 0.5;
    if (snapshot.planExpiry && snapshot.planExpiry < now) {
        maxTB = 0.5;
    }
    const maxBytes = maxTB * 1024 * 1024 * 1024 * 1024; // TB → bytes

    let filesMeta = JSON.parse(fs.readFileSync(filesMetaFile, "utf8"));
    const userFiles = filesMeta.filter(f => safeName(normalizeEmail(f.uploadedBy)) === safeEmail);
    const usedBytes = userFiles.reduce((sum, f) => sum + (f.bytes || 0), 0);
    const percent = ((usedBytes / maxBytes) * 100).toFixed(2);

    res.json({
        email,
        usedBytes,
        maxGB: maxTB * 1024,
        usedFormatted: `${(usedBytes / (1024 ** 3)).toFixed(2)} GB`,
        percent: percent > 100 ? 100 : percent
    });
});

// ================== DOWNLOAD ROUTE ==================
app.get("/download/:uploadedBy/:filename", (req, res) => {
    const { uploadedBy, filename } = req.params;
    const safeEmail = safeName(normalizeEmail(uploadedBy));
    const filePath = path.join(uploadsDir, safeEmail, "files", filename);

    if (!fs.existsSync(filePath)) {
        return res.status(404).json({ error: "❌ File not found" });
    }

    res.download(filePath, filename, (err) => {
        if (err) {
            console.error("❌ Download error:", err);
            if (!res.headersSent) {
                res.status(500).json({ error: "Download failed" });
            }
        }
    });
});

// ================== LOGIN ==================  
app.post("/login", async (req, res) => {
    const email = normalizeEmail(req.body.email);
    const password = req.body.password;
    let users = JSON.parse(fs.readFileSync(usersFile));
    const user = users.find(u => u.email === email && u.password === password);

    if (!user) {
        return res.status(401).json({ error: "❌ Invalid credentials" });
    }

    // 🚫 Permanent ban
    if (user.permanentBan) {
        fs.appendFileSync(flagsLog, `${new Date().toISOString()} | ${email} | ❌ Tried login (permanent ban)\n`);
        return res.status(403).json({
            error: "❌ Account permanently banned. Contact Admin for support.",
            reason: "permanent",
            contact: SUPER_ADMIN_EMAIL || "owner@cloudspace.com"
        });
    }

    // 🚫 Block check (temporary or manual)
    if (user.blocked) {
        // ✅ If timed block expired → auto-unblock
        if (user.blockUntil && Date.now() >= user.blockUntil) {
            user.blocked = false;
            delete user.blockUntil;
            delete user.blockedBy;

            fs.writeFileSync(usersFile, JSON.stringify(users, null, 2));
            console.log(`✅ Auto-unblocked ${user.email} after timer expired`);
        } else {
            // ⏳ Still blocked
            return res.status(403).json({
                error: "🚫 Account blocked.",
                reason: user.blockedBy || "system",
                retryUntil: user.blockUntil || null
            });
        }
    }

    // 👑 Force Super Admin role for master account
    if (email === SUPER_ADMIN_EMAIL) {
        user.role = "superadmin";
    }

    // ⚠️ Unverified user → staged auto-block system
    if (!user.verified) {
        const verifyToken = uuidv4();
        magicLinks[verifyToken] = { email, expiresAt: Date.now() + 10 * 60 * 1000 }; // 10 min
        const verifyLink = `${publicUrl || `http://localhost:${PORT}`}/magic-login?token=${verifyToken}`;

        await sendStyledMail(
            email,
            "⚠️ Verify Your Cloud Space Account",
            `
            <h2 style="color:#ffcc00;">Hello Cloud Space User,</h2>
            <p>Please verify your account within <b>10 minutes</b>.</p>
            <p>Otherwise, your account May be <b>Suspended for 24 hours</b>.</p>
            <div style="text-align:center;margin:20px 0;">
                <a href="${verifyLink}" style="display:inline-block;padding:12px 25px;
                   background:linear-gradient(135deg,#00ffcc,#0099ff);
                   color:#111;text-decoration:none;border-radius:8px;
                   font-weight:bold;box-shadow:0 0 15px #00e0ff;">
                   ✅ Verify Now
                </a>
            </div>
            <p style="text-align:center;color:#ccefff;font-size:13px;margin:6px 0 0;">
                If the button does not work, paste this link into your browser:<br>
                <a href="${verifyLink}" style="color:#00ffcc;word-break:break-all;">${verifyLink}</a>
            </p>
            <p style="text-align:center;color:#9bd7ff;font-size:12px;margin-top:4px;">
                After verification, the CloudSpace+ switch will unlock on your upload page for Platinum/Ultra users.
            </p>
            `
        );

        fs.appendFileSync(flagsLog, `${new Date().toISOString()} | ${email} | 📧 Sent verification mail\n`);

        // Stage 1: 10 min later → block for 24h
        setTimeout(async () => {
            let freshUsers = JSON.parse(fs.readFileSync(usersFile));
            const idx = freshUsers.findIndex(u => u.email === email);
            if (idx !== -1 && !freshUsers[idx].verified && !freshUsers[idx].blocked) {
                freshUsers[idx].blocked = true;
                freshUsers[idx].blockUntil = Date.now() + 24 * 60 * 60 * 1000; // 24h
                freshUsers[idx].blockedBy = "system";
                fs.writeFileSync(usersFile, JSON.stringify(freshUsers, null, 2));

                fs.appendFileSync(flagsLog, `${new Date().toISOString()} | ${email} | ⚠️ Auto-blocked 24h (unverified)\n`);

                // Stage 2: After 24h → send mail (warn about 30-day block)
                setTimeout(async () => {
                    let u2 = JSON.parse(fs.readFileSync(usersFile));
                    const i2 = u2.findIndex(u => u.email === email);
                    if (i2 !== -1 && !u2[i2].verified) {
                        await sendStyledMail(
                            email,
                            "🚫 Verify Now or Face 30-Day Block",
                            `
                            <h2 style="color:#ff4444;">Final Reminder</h2>
                            <p>Your account is blocked for <b>24 hours</b>.</p>
                            <p>If not verified within this time, you will be <b>blocked for 30 days</b>.</p>
                            <div style="text-align:center;margin:20px 0;">
                                <a href="${verifyLink}" style="display:inline-block;padding:12px 25px;
                                   background:linear-gradient(135deg,#ff4d4d,#ff9900);
                                   color:#111;text-decoration:none;border-radius:8px;
                                   font-weight:bold;box-shadow:0 0 15px #ff4444;">
                                   ✅ Verify Now
                                </a>
                            </div>
                            `
                        );

                        fs.appendFileSync(flagsLog, `${new Date().toISOString()} | ${email} | 📧 Sent 24h final reminder mail\n`);

                        // Stage 3: After 30 days → permanent ban
                        setTimeout(() => {
                            let u3 = JSON.parse(fs.readFileSync(usersFile));
                            const i3 = u3.findIndex(u => u.email === email);
                            if (i3 !== -1 && !u3[i3].verified) {
                                u3[i3].blocked = true;
                                u3[i3].permanentBan = true;
                                u3[i3].blockedBy = "system";
                                fs.writeFileSync(usersFile, JSON.stringify(u3, null, 2));

                                fs.appendFileSync(flagsLog, `${new Date().toISOString()} | ${email} | ❌ Permanently banned (never verified)\n`);

                                sendStyledMail(
                                    email,
                                    "❌ Account Permanently Banned",
                                    `<p>Sorry, your account has been permanently banned due to non-verification.</p>`
                                );
                            }
                        }, 30 * 24 * 60 * 60 * 1000); // 30 days
                    }
                }, 24 * 60 * 60 * 1000); // 24h
            }
        }, 10 * 60 * 1000); // 10 min

        return res.status(403).json({
            error: "⚠️ Please verify your account. A verification mail has been sent.",
            reason: "system"
        });
    }

    // ✅ Normal verified login
    ensureUserDirs(user.email);
    const token = signToken(user);

    res.json({
        message: "✅ Login successful",
        token,
        uid: user.uid,
        username: user.username,
        email: user.email,
        role: user.role,
        profilePic: user.profilePic || null,
        // Plan details so frontend can decide which dashboard to show
        plan: user.plan || 'free',
        storageTB: user.storageTB || 0.5,
        planExpiry: user.planExpiry || null,
        uiAccess: user.uiAccess || null,
        cloudplusUI: user.cloudplusUI || null
    });
});


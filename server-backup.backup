// ================== PLAN ACCESS PROTECTION ==================
// 🔒 Middleware to check if user has ultra plan
function checkUltraPlan(req, res, next) {
    // Require authenticated user
    if (!req.user || !req.user.email) return res.status(401).send("Unauthorized");

    try {
        const users = JSON.parse(fs.readFileSync(usersFile, "utf8"));
        const user = users.find(u => normalizeEmail(u.email) === normalizeEmail(req.user.email) || u.uid === req.user.uid);

        if (!user) return res.status(404).send("User not found");

        if (user.plan !== "ultra") {
            return res.status(403).send(`
                <html>
                    <head><title>Plan Required</title></head>
                    <body style="background:#0d1117;color:#e6edf3;font-family:Arial;text-align:center;padding:50px;">
                        <h1 style="color:#ff4444;">🚫 Ultra Plan Required</h1>
                        <p>You currently have the <b>${user.plan || 'free'}</b> plan.</p>
                        <p>Upgrade to <b>Ultra</b> to access this feature.</p>
                        <a href="payment.html?uid=${user.uid}" style="
                            display:inline-block;
                            padding:12px 30px;
                            background:linear-gradient(135deg,#00ffcc,#0099ff);
                            color:#111;
                            text-decoration:none;
                            border-radius:8px;
                            font-weight:bold;
                            margin:20px 0;">
                            💳 Upgrade Now
                        </a><br>
                        <a href="upload.html" style="color:#00ffcc;text-decoration:none;margin-top:20px;display:block;">← Back to Upload</a>
                    </body>
                </html>
            `);
        }

        // attach latest user object for downstream handlers
        req.fullUser = user;
        next();
    } catch (err) {
        console.error("❌ Plan check error:", err);
        return res.status(500).send("Server error during plan validation");
    }
}

// 🔒 Protected routes for premium uploads
app.get("/ultra-upload.html", verifyToken, checkUltraPlan, (req, res) => {
    res.sendFile(path.join(publicDir, "ultra-upload.html"));
});

// 🔐 Save token to JSON file (preserves existing structure and timestamps)
app.post("/api/save-token", verifyToken, (req, res) => {
    try {
        const { token } = req.body;
        const tokensFile = path.join(supportDir, "tokens.json");

        // Normalize existing data (supports both array and { tokens: [] })
        let raw = { tokens: [] };
        if (fs.existsSync(tokensFile)) {
            try {
                const parsed = JSON.parse(fs.readFileSync(tokensFile, "utf8"));
                if (Array.isArray(parsed)) {
                    raw.tokens = parsed;
                } else if (parsed && Array.isArray(parsed.tokens)) {
                    raw = parsed;
                }
            } catch (e) {
                console.warn("⚠️ tokens.json parse error, resetting structure", e.message);
            }
        }

        const now = new Date();
        const expiresAt = new Date(now.getTime());
        expiresAt.setFullYear(expiresAt.getFullYear() + 1); // 1 year validity

        const tokenEntry = {
            email: req.user.email,
            uid: req.user.uid,
            plan: req.user.plan || "",
            token: token,
            createdAt: now.toISOString(),
            expiresAt: expiresAt.toISOString(),
            used: false,
            active: true,
            ipAddress: req.ip || req.connection?.remoteAddress || ""
        };

        // Remove old entries for this user (by uid or email)
        raw.tokens = (raw.tokens || []).filter(t => t.email !== req.user.email && t.uid !== req.user.uid);

        // Add new entry
        raw.tokens.push(tokenEntry);

        // Keep only last 100 entries
        if (raw.tokens.length > 100) {
            raw.tokens = raw.tokens.slice(-100);
        }

        fs.writeFileSync(tokensFile, JSON.stringify(raw, null, 2));
        
        res.json({ success: true, message: "Token saved successfully", token: tokenEntry });
    } catch (error) {
        console.error("Token save error:", error);
        res.status(500).json({ success: false, message: "Failed to save token" });
    }
});

// 🔐 Token-validated access route for platinum-ui-upload.html
app.get("/platinum-ui-upload.html", (req, res) => {
    try {
        const token = req.query.token || req.headers['x-access-token'];
        const uid = req.query.uid || req.user?.uid;
        
        // 🔒 First check: Validate token if provided
        if (token) {
            const validToken = validateToken(token);
            if (validToken) {
                // Token is valid, allow access
                return res.sendFile(path.join(publicDir, "platinum-ui-upload.html"));
            } else {
                // Token provided but invalid
                return res.status(403).send(`
                    <html>
                        <head><title>Invalid Token</title></head>
                        <body style="background:#0d1117;color:#e6edf3;font-family:Arial;text-align:center;padding:50px;">
                            <h1 style="color:#ff4444;">⚠️ Invalid or Expired Token</h1>
                            <p>Your access token is invalid or has expired.</p>
                            <a href="upgrade-form.html" style="
                                display:inline-block;
                                padding:12px 30px;
                                background:linear-gradient(135deg,#ff6b6b,#ff8e00);
                                color:#111;
                                text-decoration:none;
                                border-radius:8px;
                                font-weight:bold;
                                margin:20px 0;">
                                🔄 Get New Token
                            </a>
                        </body>
                    </html>
                `);
            }
        }
        
        // 🔓 Alternative: If no token but has JWT auth, check if user has platinum/ultra plan
        if (req.user && req.user.uid) {
            try {
                const users = JSON.parse(fs.readFileSync(usersFile, "utf8"));
                const user = users.find(u => u.uid === req.user.uid);
                const planSnapshot = getActivePlanSnapshot(req.user.uid);
                
                // Allow if user has platinum or ultra plan
                if (planSnapshot.plan === "platinum" || planSnapshot.plan === "ultra") {
                    return res.sendFile(path.join(publicDir, "platinum-ui-upload.html"));
                }
            } catch (err) {
                console.error("❌ Plan check error:", err);
            }
        }
        
        // ❌ No valid token or plan - deny access
        return res.status(401).send(`
            <html>
                <head><title>Access Denied</title></head>
                <body style="background:#0d1117;color:#e6edf3;font-family:Arial;text-align:center;padding:50px;">
                    <h1 style="color:#ff4444;">🔐 Access Token Required</h1>
                    <p>You need a valid access token or platinum/ultra plan to view this page.</p>
                    <p>Please complete your payment to receive your token.</p>
                    <a href="upgrade-form.html" style="
                        display:inline-block;
                        padding:12px 30px;
                        background:linear-gradient(135deg,#00d4ff,#7c3aed);
                        color:#fff;
                        text-decoration:none;
                        border-radius:8px;
                        font-weight:bold;
                        margin:20px 0;">
                        💳 Purchase Plan
                    </a>
                </body>
            </html>
        `);
    } catch (err) {
        console.error("❌ Platinum token validation error:", err);
        return res.status(500).send("Server error");
    }
});

// Deprecated old route - redirect to token-based
app.get("/platinum-upload.html", (req, res) => {
    res.redirect("/platinum-ui-upload.html?token=" + (req.query.token || ""));
});

// ================== Static ==================
// Protected Cloud+ UI under uploads - serve only to owner or admins
app.get('/uploads/:user/cloudplus_ui/*', verifyToken, (req, res) => {
    try {
        const reqUser = req.user;
        const requestedFolder = req.params.user;
        const users = JSON.parse(fs.readFileSync(usersFile, 'utf8'));
        const owner = users.find(u => safeName(u.email) === requestedFolder);

        if (!owner) return res.status(404).send('Not found');

        const isOwner = normalizeEmail(owner.email) === normalizeEmail(reqUser.email) || owner.uid === reqUser.uid;
        if (!isOwner && reqUser.role !== 'admin' && reqUser.role !== 'superadmin') {
            return res.status(403).send('Forbidden');
        }

        const rest = req.params[0] || '';
        const filePath = path.join(uploadsDir, requestedFolder, 'cloudplus_ui', rest);
        if (!fs.existsSync(filePath)) return res.status(404).send('Not found');
        return res.sendFile(filePath);
    } catch (err) {
        console.error('cloudplus serve error', err);
        return res.status(500).send('Server error');
    }
});

app.get('/uploads/:user/cloudplus_ui', verifyToken, (req, res) => {
    try {
        const requestedFolder = req.params.user;
        const indexPath = path.join(uploadsDir, requestedFolder, 'cloudplus_ui', 'index.html');
        if (!fs.existsSync(indexPath)) return res.status(404).send('Not found');
        return res.sendFile(indexPath);
    } catch (err) {
        console.error('cloudplus index error', err);
        return res.status(500).send('Server error');
    }
});

// General uploads static (after protected cloudplus handlers)
app.use("/uploads", express.static(uploadsDir));
app.use(express.static(publicDir));
app.use("/cloudplus", express.static(path.join(__dirname, "public3")));

// Quiet the default browser request for /favicon.ico to avoid noisy 404s
app.get("/favicon.ico", (_req, res) => res.status(204).end());

// ================== Default Route ==================

app.post("/process-card", verifyToken, (req, res) => {
    const { cardNumber, cardName, expiry, cvv, uid, plan, amount, discountedAmount } = req.body;

    if (!cardNumber || !cardName || !expiry || !cvv) {
        return res.json({ success: false, msg: "Incomplete card details" });
    }

    // Determine target UID: prefer body.uid, else token uid
    const targetUid = uid || req.user?.uid;

    console.log(`💳 Card processed (SIMULATED) → UID=${targetUid}, Plan=${plan}, Amount=${amount}`);

    try {
        let users = JSON.parse(fs.readFileSync(usersFile, "utf8") || "[]");
        const userIdx = users.findIndex(u => u.uid === targetUid || normalizeEmail(u.email) === normalizeEmail(req.user?.email));

        if (userIdx === -1) {
            return res.status(404).json({ success: false, msg: "User not found" });
        }

        const selected = PLANS[plan];
        if (!selected) {
            return res.status(400).json({ success: false, msg: "Invalid plan" });
        }

        const transactionId = "CARD-" + Date.now();
        const cardLast4 = cardNumber.slice(-4);
        const finalAmount = discountedAmount || amount;
        const amountDiscount = amount - finalAmount;
        const discountPercent = amountDiscount > 0 ? Math.round((amountDiscount / amount) * 100) : 0;

        // Compute expiry for response (persisted via purchases/plan-active, not users.json)
        const planExpiry = selected.durationDays === 9999 ? null : Date.now() + selected.durationDays * 24 * 60 * 60 * 1000;

        // Copy Cloud+ UI and uiAccess without storing plan fields back into users.json
        let userMutated = false;
        if (plan === "ultra") {
            users[userIdx].uiAccess = "ultra";
            userMutated = true;
            try {
                const userEmailSafe = safeName(users[userIdx].email);
                const destUi = path.join(uploadsDir, userEmailSafe, 'cloudplus_ui');
                const srcUi = path.join(__dirname, 'public3');
                const copied = copyDirRecursive(srcUi, destUi);
                if (copied) {
                    users[userIdx].cloudplusUI = `/uploads/${userEmailSafe}/cloudplus_ui/index.html`;
                }
            } catch (e) {
                console.warn('Failed to copy Cloud+ UI for user', e);
            }
        }

        if (userMutated) {
            fs.writeFileSync(usersFile, JSON.stringify(users, null, 2));
        }

        // Log the purchase
        logPurchase(
            users[userIdx],
            plan,
            amount,
            amountDiscount,
            discountPercent,
            finalAmount,
            'card',
            transactionId,
            null,
            cardLast4,
            `Card payment by ${cardName}`
        );

        return res.json({ success: true, tx: transactionId, user: { uid: users[userIdx].uid, plan, storageTB: selected.storageTB, planExpiry, cloudplusUI: users[userIdx].cloudplusUI || null } });
    } catch (err) {
        console.error('❌ process-card error:', err);
        return res.status(500).json({ success: false, msg: 'Internal error' });
    }
});


app.get("/verify-upi", verifyToken, (req, res) => {
  const { upi } = req.query;
  if (!upi) {
    return res.json({ success: false, msg: "UPI missing" });
  }

  const upiRegex = /^[\w.\-]{2,}@[a-zA-Z]{2,}$/;
  const validFormat = upiRegex.test(upi);

  return res.json({
    success: true,
    validFormat,
    exists: validFormat,              // simulated
    matchesConfigured: upi === UPI_ID // exact match check
  });
});



// ----------------- Create Payment QR -----------------
app.post("/create-qr", async (req, res) => {
    try {
        const { uid, plan, coupon, amount: customAmount, requestedStorageTB } = req.body;
        if (!uid || !plan) return res.json({ success: false, msg: "Missing uid or plan" });

        let selected = PLANS[plan];
        let customTB = null;

        if (plan === "custom") {
            customTB = Number(requestedStorageTB || req.body.storageTB || req.body.tb || NaN);
            let customAmt = Number(customAmount || NaN);
            if (!Number.isFinite(customTB) || customTB < 1) {
                return res.json({ success: false, msg: "Invalid custom storage TB" });
            }
            if (!Number.isFinite(customAmt) || customAmt <= 0) {
                customAmt = Math.round(customTB * PRICE_PER_TB);
            }
            if (!Number.isFinite(customAmt) || customAmt <= 0) {
                return res.json({ success: false, msg: "Invalid custom amount" });
            }
            selected = {
                name: `Custom ${customTB} TB`,
                amount: customAmt,
                storageTB: customTB,
                durationDays: 30
            };
        }

        if (!selected) return res.json({ success: false, msg: "Invalid plan" });

        let amount = selected.amount;

        // Apply discount if coupon is valid (your VALID_COUPON & DISCOUNT_PERCENT expected in scope)
        let discountApplied = 0;
        console.log(`📋 Processing: coupon="${coupon}", VALID_COUPON="${VALID_COUPON}", DISCOUNT_PERCENT=${DISCOUNT_PERCENT}`);
        if (
          coupon &&
          typeof VALID_COUPON !== "undefined" &&
          coupon.toUpperCase() === VALID_COUPON.toUpperCase() &&
          typeof DISCOUNT_PERCENT !== "undefined" &&
          DISCOUNT_PERCENT > 0
        ) {
            discountApplied = (amount * DISCOUNT_PERCENT) / 100;
            amount = amount - discountApplied;
            console.log(`✅ COUPON VALID! Discount: ₹${discountApplied} (${DISCOUNT_PERCENT}%), Final: ₹${amount}`);
        } else {
            if (coupon && coupon.toUpperCase() !== VALID_COUPON.toUpperCase()) {
                console.log(`❌ COUPON INVALID: "${coupon}" does not match "${VALID_COUPON}"`);
            }
        }

        const upiUri = `upi://pay?pa=${UPI_ID}&pn=CloudSpace%20Payment&am=${amount}&cu=INR&tn=${selected.name}%20Plan%20for%20${uid}`;
        const qrDataUrl = await QRCode.toDataURL(upiUri);

        res.json({
            success: true,
            qrDataUrl,
            amount,
            upiUri,
            discountApplied,
            discountPercent: discountApplied > 0 ? DISCOUNT_PERCENT : 0,
            requestedStorageTB: customTB
        });
    } catch (err) {
        console.error("❌ QR Generation Error:", err);
        res.json({ success: false, msg: "QR generation failed" });
    }
});


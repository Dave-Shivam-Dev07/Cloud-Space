app.post("/forgot-password", (req, res) => {
    // after
    const email = normalizeEmail(req.body.email);
    const phone = req.body.phone;
    const uid = req.body.uid;
    if (!email || !phone || !uid) {
        return res.status(400).json({ error: "❌ Email, phone and UID are required" });
    }


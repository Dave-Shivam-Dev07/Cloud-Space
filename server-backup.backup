// ================== ENSURE SUPPORT FILES ==================
function ensureSupportData() {
  if (!fs.existsSync(supportDir)) fs.mkdirSync(supportDir);
  if (!fs.existsSync(supportDataDir)) fs.mkdirSync(supportDataDir);

  if (!fs.existsSync(supportFiles.reasons))
    fs.writeFileSync(supportFiles.reasons, JSON.stringify(supportDefaults.reasons, null, 2));

  if (!fs.existsSync(supportFiles.priorities))
    fs.writeFileSync(supportFiles.priorities, JSON.stringify(supportDefaults.priorities, null, 2));

  if (!fs.existsSync(supportFiles.socials))
    fs.writeFileSync(supportFiles.socials, JSON.stringify(supportDefaults.socials, null, 2));
}

ensureSupportData();


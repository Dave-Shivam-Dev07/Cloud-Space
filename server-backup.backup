// ================== Helpers ==================
// Utility to sanitize names
function safeName(name) {
    return name.replace(/[^a-z0-9]/gi, "_").toLowerCase();
}
function generateUID() {
    return "USR-" + Math.random().toString(36).substring(2, 10).toUpperCase();
}
function generateStrongPassword() {
    // 6-digit numeric for easy SMS/email sharing
    return String(Math.floor(100000 + Math.random() * 900000));
}
function signToken(user) {
    return jwt.sign({ email: user.email, role: user.role, uid: user.uid }, JWT_SECRET, {
        expiresIn: "2h",
    });
}
function verifyToken(req, res, next) {
    // Accept token from Authorization header, query param `token`, or cookie named `token`
    let token = null;
    const auth = req.headers["authorization"];
    if (auth && auth.split(" ").length > 1) token = auth.split(" ")[1];
    if (!token && req.query && req.query.token) token = req.query.token;
    if (!token && req.headers && req.headers.cookie) {
        const cookies = req.headers.cookie.split(";").map(c => c.trim());
        for (const c of cookies) {
            if (c.startsWith('token=')) {
                token = c.split('=')[1];
                break;
            }
        }
    }

    if (!token) return res.status(401).json({ error: "No token" });
    try {
        req.user = jwt.verify(token, JWT_SECRET);
        next();
    } catch {
        return res.status(403).json({ error: "Invalid token" });
    }
}
function isAdmin(req, res, next) {
    if (req.user.role !== "admin" && req.user.role !== "superadmin") {
        return res.status(403).json({ error: "Admins only" });
    }
    next();
}
function normalizeEmail(email) {
    return email ? email.trim().toLowerCase() : "";
}

// Resolve both email and uid from body/header/token
function resolveUserContext(req) {
    const body = req.body || {};
    const headers = req.headers || {};

    let email = normalizeEmail(
        body.email ||
        body.uploadedBy ||
        headers["x-email"] ||
        headers["x-user"]
    );

    let uid = body.uid || body.userId || body.id || headers["x-uid"];

    // Fallback to JWT token if present
    let token = null;
    const auth = headers["authorization"];
    if (auth && auth.split(" ").length > 1) token = auth.split(" ")[1];
    if (!token && req.query && req.query.token) token = req.query.token;
    if (!token && headers.cookie) {
        const cookies = headers.cookie.split(";").map(c => c.trim());
        for (const c of cookies) {
            if (c.startsWith("token=")) {
                token = c.split("=")[1];
                break;
            }
        }
    }

    if (token) {
        try {
            const decoded = jwt.verify(token, JWT_SECRET);
            if (!email && decoded.email) email = normalizeEmail(decoded.email);
            if (!uid && decoded.uid) uid = decoded.uid;
        } catch (err) {
            // ignore and fall back
        }
    }

    return { email, uid };
}

// Backward-compatible single identifier
function resolveUploadedBy(req) {
    const ctx = resolveUserContext(req);
    return ctx.uid || ctx.email || "guest";
}

// Create uploads/email/uid/(files|profile|chunks)
function ensureUserDirs(email, uid) {
    const safeEmail = email ? safeName(email) : "";
    const safeUid = uid ? safeName(uid) : "";
    const pathSegment = safeEmail && safeUid ? path.join(safeEmail, safeUid) : (safeEmail || safeUid || "guest");

    const baseDir = path.join(uploadsDir, pathSegment);
    const filesDir = path.join(baseDir, "files");
    const profileDir = path.join(baseDir, "profile");
    const chunksDir = path.join(baseDir, "chunks");

    if (!fs.existsSync(baseDir)) fs.mkdirSync(baseDir, { recursive: true });
    [filesDir, profileDir, chunksDir].forEach(d => {
        if (!fs.existsSync(d)) fs.mkdirSync(d, { recursive: true });
    });

    // Default profile.png
    const defaultProfileSrc = path.join(publicDir, "images", "default-profile.png");
    const defaultProfileDest = path.join(profileDir, "profile.png");
    if (fs.existsSync(defaultProfileSrc) && !fs.existsSync(defaultProfileDest)) {
        fs.copyFileSync(defaultProfileSrc, defaultProfileDest);
        console.log(`📷 Default profile.png added for ${pathSegment}`);
    }

    return { base: baseDir, files: filesDir, profile: profileDir, chunks: chunksDir, pathSegment };
}
function appendLog(filePath, msg) {
    const logs = fs.existsSync(filePath) ? JSON.parse(fs.readFileSync(filePath)) : {};
    const timestamp = new Date().toLocaleString();
    if (!logs.flagLogs) logs.flagLogs = "";
    logs.flagLogs += `[${timestamp}] ${msg}\n`;
    fs.writeFileSync(filePath, JSON.stringify(logs, null, 2));
}


// Token System for Platinum/Ultra Plans
import fs from "fs";
import path from "path";
import { fileURLToPath } from "url";
import jwt from "jsonwebtoken";

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

const tokensFile = path.join(__dirname, "support", "tokens.json");
const JWT_SECRET = "your_jwt_secret"; // Ensure you use a strong secret and keep it safe

// Generate token in format: PTK-USR + 6 digits for platinum, UTK-USR + 6 digits for ultra
function generateToken(plan) {
  let numbers = "";
  for (let i = 0; i < 6; i++) {
    numbers += Math.floor(Math.random() * 10);
  }
  
  // Different prefix based on plan
  if (plan === 'platinum') {
    return `PTK-USR${numbers}`;
  } else if (plan === 'ultra') {
    return `UTK-USR${numbers}`;
  } else {
    return `TOK-CS${numbers}`; // fallback
  }
}

// Create and save token for user - ONE TOKEN PER USER (not regeneratable)
// durationDays controls token expiry; defaults to plan-based (platinum=180 days, ultra=lifetime)
export function createPlatinumToken(uid, plan, email = null, ipAddress = null, durationDays = null) {
  try {
    let tokenData = { tokens: [] };
    
    if (fs.existsSync(tokensFile)) {
      try {
        const fileContent = fs.readFileSync(tokensFile, "utf8");
        if (fileContent.trim()) {
          tokenData = JSON.parse(fileContent);
          // Ensure tokens array exists
          if (!tokenData.tokens || !Array.isArray(tokenData.tokens)) {
            tokenData.tokens = [];
          }
        }
      } catch (parseErr) {
        console.warn("⚠️ tokens.json corrupted, reinitializing...");
        tokenData = { tokens: [] };
      }
    }
    
    // Decide expiry based on plan if not provided
    const effectiveDuration = durationDays !== null && durationDays !== undefined
      ? durationDays
      : (plan === 'ultra' ? 9999 : 180);
    const desiredExpiresAt = effectiveDuration === 9999
      ? null
      : new Date(Date.now() + effectiveDuration * 24 * 60 * 60 * 1000).toISOString();
    
    // ✅ CHECK IF TOKEN ALREADY EXISTS FOR THIS USER - DON'T REGENERATE!
    const existingToken = tokenData.tokens.find(t => t.uid === uid && t.plan === plan);
    if (existingToken) {
      // Update expiry, reactivate, and reset reminder flags on renewal
      if (desiredExpiresAt) {
        existingToken.expiresAt = desiredExpiresAt;
      }
      existingToken.reminderSent = false;
      existingToken.remindedAt = null;
      existingToken.active = true;
      existingToken.used = false;
      existingToken.expiredAt = null;
      fs.writeFileSync(tokensFile, JSON.stringify(tokenData, null, 2));
      console.log(`♻️ Token refreshed for UID=${uid}, Plan=${plan}. Token: ${existingToken.token}`);
      return existingToken.token;
    }
    
    const token = generateToken(plan);
    const newToken = {
      email,
      uid,
      plan,
      token,
      createdAt: new Date().toISOString(),
      expiresAt: desiredExpiresAt,
      reminderSent: false,
      remindedAt: null,
      used: false,
      active: true,
      ipAddress
    };
    
    tokenData.tokens.push(newToken);
    fs.writeFileSync(tokensFile, JSON.stringify(tokenData, null, 2));
    
    console.log(`✅ Token generated for UID=${uid}, Plan=${plan}, Email=${email}, Token=${token}`);
    return token;
  } catch (err) {
    console.error("❌ Error creating token:", err);
    return null;
  }
}

// Validate token
export function validateToken(token) {
  try {
    if (!fs.existsSync(tokensFile)) return null;
    
    const tokenData = JSON.parse(fs.readFileSync(tokensFile, "utf8"));
    if (!tokenData.tokens || !Array.isArray(tokenData.tokens)) return null;
    const foundToken = tokenData.tokens.find(t => t.token === token);
    
    if (!foundToken) return null;

    // Must be active
    if (foundToken.active === false) return null;
    
    // Check if expired
    if (new Date(foundToken.expiresAt) < new Date()) {
      return null;
    }
    
    return foundToken;
  } catch (err) {
    console.error("❌ Error validating token:", err);
    return null;
  }
}

// Get token by UID (for internal use only)
export function getTokenByUID(uid) {
  try {
    if (!fs.existsSync(tokensFile)) return null;
    
    const fileContent = fs.readFileSync(tokensFile, "utf8");
    if (!fileContent.trim()) return null;
    
    const tokenData = JSON.parse(fileContent);
    if (!tokenData.tokens || !Array.isArray(tokenData.tokens)) return null;
    
    // Find token by UID that is active (ignore 'used' flag)
    return tokenData.tokens.find(t => t.uid === uid && t.active !== false);
  } catch (err) {
    console.error("❌ Error getting token:", err);
    return null;
  }
}

// Mark token as used
export function markTokenAsUsed(token) {
  try {
    const tokenData = JSON.parse(fs.readFileSync(tokensFile, "utf8"));
    const foundToken = tokenData.tokens.find(t => t.token === token);
    
    if (foundToken) {
      foundToken.used = true;
      foundToken.usedAt = new Date().toISOString();
      fs.writeFileSync(tokensFile, JSON.stringify(tokenData, null, 2));
    }
  } catch (err) {
    console.error("❌ Error marking token as used:", err);
  }
}

// Mark token as used in the current session (prevents reuse)
export function markTokenAsUsed(token, sessionId) {
  try {
    if (!fs.existsSync(tokensFile)) return false;
    
    const tokenData = JSON.parse(fs.readFileSync(tokensFile, "utf8"));
    const foundToken = tokenData.tokens.find(t => t.token === token);
    
    if (foundToken) {
      // Record this usage session
      if (!foundToken.sessions) foundToken.sessions = [];
      foundToken.sessions.push({
        sessionId,
        usedAt: new Date().toISOString(),
      });
      
      // Keep only last 5 sessions for security audit
      if (foundToken.sessions.length > 5) {
        foundToken.sessions = foundToken.sessions.slice(-5);
      }
      
      foundToken.lastUsedAt = new Date().toISOString();
      fs.writeFileSync(tokensFile, JSON.stringify(tokenData, null, 2));
      console.log(`✅ Token usage recorded - SessionID: ${sessionId}`);
      return true;
    }
    
    return false;
  } catch (err) {
    console.error("❌ Error marking token as used:", err);
    return false;
  }
}

// Validate token hasn't been reused with different session
export function validateTokenSession(token, sessionId) {
  try {
    if (!fs.existsSync(tokensFile)) return false;
    
    const tokenData = JSON.parse(fs.readFileSync(tokensFile, "utf8"));
    const foundToken = tokenData.tokens.find(t => t.token === token);
    
    if (!foundToken) return false;
    
    // Check if token has been used in a different session
    if (foundToken.sessions && foundToken.sessions.length > 0) {
      // If token was already used, check if it's the same session
      const differentSessions = foundToken.sessions.filter(s => s.sessionId !== sessionId);
      if (differentSessions.length > 0) {
        console.warn(`⚠️ Token reuse attempt detected! Original session: ${foundToken.sessions[0].sessionId}, New session: ${sessionId}`);
        return false; // Token has been used in a different session!
      }
    }
    
    return true; // Token is valid for this session
  } catch (err) {
    console.error("❌ Error validating token session:", err);
    return false;
  }
}

// Toggle token active/inactive status - EDITABLE FROM JSON FILE
export function setTokenStatus(uid, active) {
  try {
    if (!fs.existsSync(tokensFile)) return false;
    
    const tokenData = JSON.parse(fs.readFileSync(tokensFile, "utf8"));
    const foundToken = tokenData.tokens.find(t => t.uid === uid);
    
    if (foundToken) {
      foundToken.active = active;
      foundToken.statusUpdatedAt = new Date().toISOString();
      fs.writeFileSync(tokensFile, JSON.stringify(tokenData, null, 2));
      console.log(`✅ Token status updated for UID=${uid}: active=${active}`);
      return true;
    }
    
    console.warn(`⚠️ Token not found for UID=${uid}`);
    return false;
  } catch (err) {
    console.error("❌ Error setting token status:", err);
    return false;
  }
}

// Middleware to protect routes
export function authenticateToken(req, res, next) {
  const authHeader = req.headers["authorization"];
  const token = authHeader && authHeader.split(" ")[1]; // Bearer TOKEN

  if (!token) return res.sendStatus(401); // Unauthorized

  jwt.verify(token, JWT_SECRET, (err, user) => {
    if (err) return res.sendStatus(403); // Forbidden
    req.user = user;
    next();
  });
  
  const tokenEntry = validateToken(token);
  if (!tokenEntry) {
    return res.status(403).json({ error: "Invalid or expired token" });
  }
  req.user = {
    uid: tokenEntry.uid,
    email: tokenEntry.email,
    plan: tokenEntry.plan,
    token: tokenEntry.token
  };
}
